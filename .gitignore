# ===================================================
# Dependencies
# ===================================================
node_modules/
.pnp
.pnp.js

# ===================================================
# Next.js build output
# ===================================================
.next/
out/
build/

# ===================================================
# Environment files — NEVER commit real credentials
# ===================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Allow example/template env files (no real secrets)
!.env.example
!.env.production.example

# ===================================================
# Database files
# ===================================================
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/dev.db
prisma/dev.db-journal

# ===================================================
# User-uploaded files (served from public/uploads)
# ===================================================
public/uploads/

# ===================================================
# Logs
# ===================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ===================================================
# OS metadata
# ===================================================
.DS_Store
Thumbs.db
desktop.ini

# ===================================================
# Certificates / keys
# ===================================================
*.pem
*.key
*.crt
*.pfx

# ===================================================
# Editor / IDE
# ===================================================
.vscode/settings.json
.idea/
*.swp
*.swo

# ===================================================
