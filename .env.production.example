# Production Environment Variables Example
# Copy this file to .env.production and update with your values

# Application
NODE_ENV=production
PORT=3000

# Database (PostgreSQL - for Docker production)
DATABASE_URL=postgresql://piyabordee:CHANGE_ME_PASSWORD@postgres:5432/piyabordee_shop?schema=public
DB_PASSWORD=CHANGE_ME_PASSWORD

# Admin Authentication
# IMPORTANT: Use strong passwords and random secrets (minimum 32 characters)
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_TOKEN_SECRET=CHANGE_ME_RANDOM_SECRET_KEY_MINIMUM_32_CHARS

# Nginx Reverse Proxy (Optional)
NGINX_PORT=80
NGINX_SSL_PORT=443

# For local development with SQLite (uncomment below)
# DATABASE_URL="file:./dev.db"
